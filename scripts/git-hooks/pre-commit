#!/usr/bin/env bash
# Versioning guard. Install with: scripts/install-hooks.sh (sets core.hooksPath).
# 1) versions must be consistent (check-version.sh)
# 2) if functional code changed, the canonical version must differ from HEAD (i.e. you bumped it)
# Override a single commit with: SKIP_VERSION_CHECK=1 git commit …
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

if [ "${SKIP_VERSION_CHECK:-}" = "1" ]; then
  echo "pre-commit: SKIP_VERSION_CHECK=1 — skipping version guard" >&2
  exit 0
fi

# (1) consistency
"$ROOT/scripts/check-version.sh" >/dev/null

# (2) bump-on-change
staged="$(git diff --cached --name-only)"
if echo "$staged" | grep -qE '^(src/|web/src/|scripts/|herdr-plugin\.toml)'; then
  read_ver() { sed -n 's/^[[:space:]]*version[[:space:]]*=[[:space:]]*"\([^"]*\)".*/\1/p' | head -1; }
  cur="$(read_ver < "$ROOT/herdr-plugin.toml")"
  prev="$(git show HEAD:herdr-plugin.toml 2>/dev/null | read_ver || true)"
  if [ -n "${prev:-}" ] && [ "$cur" = "$prev" ]; then
    cat >&2 <<EOF
✗ pre-commit: functional code changed but the version is still $cur.
  Bump version in herdr-plugin.toml, package.json, web/package.json and add a CHANGELOG entry.
  (Doc-only changes don't need a bump. Override once with SKIP_VERSION_CHECK=1 git commit.)
EOF
    exit 1
  fi
fi

exit 0
